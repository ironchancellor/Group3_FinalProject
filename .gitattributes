# ── Excel helpers ─────────────────────────────────────────────────────────────
BLUE_DARK    = "1A3C5E"
BLUE_LIGHT   = "D6E8F7"
ALT_ROW      = "EEF4FB"
WHITE        = "FFFFFF"

def hdr_style(cell, *, bg=BLUE_DARK, fg=WHITE):
    cell.font      = Font(name="Arial", bold=True, color=fg, size=11)
    cell.fill      = PatternFill("solid", start_color=bg)
    cell.alignment = Alignment(horizontal="center", vertical="center")
    cell.border    = thin_border()

def thin_border(color="CCCCCC"):
    s = Side(style="thin", color=color)
    return Border(left=s, right=s, top=s, bottom=s)

# ── Build Excel workbook ──────────────────────────────────────────────────────
def build_workbook(movies: list[dict]) -> Workbook:
    # Sort by rating desc
    movies.sort(key=lambda m: m["Rating"], reverse=True)

    wb = Workbook()

    # ── Sheet 1: Movie Catalog ────────────────────────────────────────────────
    ws = wb.active
    ws.title = "Movie Catalog"

    COLS = ["ID", "Title", "Release Date", "Rating",
            "Vote Count", "Popularity", "Genres", "Overview"]
    COL_W = {"ID": 9, "Title": 36, "Release Date": 14, "Rating": 9,
              "Vote Count": 12, "Popularity": 12, "Genres": 30, "Overview": 60}

    # Header
    ws.row_dimensions[1].height = 22
    for c, h in enumerate(COLS, 1):
        cell = ws.cell(row=1, column=c, value=h)
        hdr_style(cell)

    # Data
    alt = PatternFill("solid", start_color=ALT_ROW)
    for ri, movie in enumerate(movies, 2):
        for ci, key in enumerate(COLS, 1):
            cell = ws.cell(row=ri, column=ci, value=movie[key])
            cell.font   = Font(name="Arial", size=10)
            cell.border = thin_border()
            if ri % 2 == 0:
                cell.fill = alt
            if key in ("ID", "Rating", "Vote Count", "Popularity"):
                cell.alignment = Alignment(horizontal="center", vertical="center")
            elif key == "Overview":
                cell.alignment = Alignment(wrap_text=True, vertical="top")
                ws.row_dimensions[ri].height = 58
            else:
                cell.alignment = Alignment(vertical="center")

    # Column widths & freeze
    for ci, h in enumerate(COLS, 1):
        ws.column_dimensions[get_column_letter(ci)].width = COL_W[h]
    ws.freeze_panes = "A2"

    # ── Sheet 2: Summary ──────────────────────────────────────────────────────
    ss = wb.create_sheet("Summary")
    ss.column_dimensions["A"].width = 28
    ss.column_dimensions["B"].width = 22
    ss.column_dimensions["C"].width = 14

    # Title block
    ss["A1"] = "TMDB Popular Movies — Summary"
    ss["A1"].font = Font(name="Arial", bold=True, size=14, color=BLUE_DARK)
    ss["A2"] = f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}"
    ss["A2"].font = Font(name="Arial", size=9, italic=True, color="888888")

    ss["A4"] = "Key Statistics"
    ss["A4"].font = Font(name="Arial", bold=True, size=12, color=BLUE_DARK)

    stat_fill = PatternFill("solid", start_color=BLUE_LIGHT)
    stats = [
        ("Total movies",        "=COUNTA('Movie Catalog'!B2:B10000)"),
        ("Average rating",      "=AVERAGE('Movie Catalog'!D2:D10000)"),
        ("Highest rating",      "=MAX('Movie Catalog'!D2:D10000)"),
        ("Lowest rating",       "=MIN('Movie Catalog'!D2:D10000)"),
        ("Total votes",         "=SUM('Movie Catalog'!E2:E10000)"),
        ("Avg popularity",      "=AVERAGE('Movie Catalog'!F2:F10000)"),
    ]
    num_fmts = {"Average rating": "0.00", "Highest rating": "0.00",
                "Lowest rating": "0.00", "Avg popularity": "#,##0.00",
                "Total votes": "#,##0"}

    for i, (label, formula) in enumerate(stats, 5):
        lc = ss.cell(row=i, column=1, value=label)
        vc = ss.cell(row=i, column=2, value=formula)
        for c in (lc, vc):
            c.font   = Font(name="Arial", size=10, bold=(c == lc))
            c.fill   = stat_fill
            c.border = thin_border()
        vc.alignment = Alignment(horizontal="center")
        if label in num_fmts:
            vc.number_format = num_fmts[label]

    ss["A12"] = "Top 5 by Rating"
    ss["A12"].font = Font(name="Arial", bold=True, size=12, color=BLUE_DARK)

    for ci, h in enumerate(["Title", "Rating", "Release Date"], 1):
        hdr_style(ss.cell(row=13, column=ci))
        ss.cell(row=13, column=ci, value=h)

    for ri, movie in enumerate(movies[:5], 14):
        ss.cell(row=ri, column=1, value=movie["Title"]).font  = Font(name="Arial", size=10)
        rc = ss.cell(row=ri, column=2, value=movie["Rating"])
        rc.font      = Font(name="Arial", size=10)
        rc.alignment = Alignment(horizontal="center")
        ss.cell(row=ri, column=3, value=movie["Release Date"]).font = Font(name="Arial", size=10)

    return wb

# ── Main ──────────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    if API_KEY in ("YOUR_API_KEY_HERE", ""):
        print("⚠️  No TMDB API key found — using mock data for demonstration.")
        print("   Set API_KEY or env var TMDB_API_KEY to fetch live data.\n")
        movies = MOCK_MOVIES
    else:
        print("Connecting to TMDB API…")
        movies = fetch_movies()

    print(f"Processing {len(movies)} movies…")
    wb = build_workbook(movies)
    wb.save(OUTPUT)
    print(f"✅  Saved → {OUTPUT}")
