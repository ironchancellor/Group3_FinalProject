"""
tmdb_to_excel.py
────────────────────────────────────────────────────────────────────────────
Fetches popular movie data from The Movie Database (TMDB) API and writes a
formatted Excel workbook with two sheets:
  1. Movie Catalog  — all fetched movies with key metadata
  2. Summary        — stats + top-5 table, all driven by Excel formulas

Usage
-----
1. Get a free API key at https://developer.themoviedb.org
2. Set it in the API_KEY constant below (or via env var TMDB_API_KEY).
3. pip install requests openpyxl
4. python tmdb_to_excel.py
"""

import os
import requests
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter
from datetime import datetime

# ── Configuration ─────────────────────────────────────────────────────────────
BASE_URL = "https://api.themoviedb.org/3"
API_KEY  = os.getenv("TMDB_API_KEY", "YOUR_API_KEY_HERE")  # ← put your key here
OUTPUT   = "tmdb_movies.xlsx"
PAGES    = 3   # 20 movies per page → 60 movies total

# ── Helpers ───────────────────────────────────────────────────────────────────
def tmdb_get(endpoint: str, params: dict = None) -> dict:
    """Make a GET request to the TMDB API."""
    p = {"api_key": API_KEY, "language": "en-US", **(params or {})}
    resp = requests.get(f"{BASE_URL}{endpoint}", params=p, timeout=10)
    resp.raise_for_status()
    return resp.json()

# ── Fetch from TMDB ───────────────────────────────────────────────────────────
def fetch_movies() -> list[dict]:
    """Fetch popular movies (multiple pages) and resolve genre names."""
    # Genre lookup
    genre_map = {g["id"]: g["name"]
                 for g in tmdb_get("/genre/movie/list")["genres"]}

    movies = []
    for page in range(1, PAGES + 1):
        print(f"  Fetching page {page}/{PAGES}…")
        for m in tmdb_get("/movie/popular", {"page": page})["results"]:
            movies.append({
                "ID":           m["id"],
                "Title":        m.get("title", ""),
                "Release Date": m.get("release_date", ""),
                "Rating":       round(m.get("vote_average", 0), 1),
                "Vote Count":   m.get("vote_count", 0),
                "Popularity":   round(m.get("popularity", 0), 2),
                "Genres":       ", ".join(genre_map.get(gid, "")
                                          for gid in m.get("genre_ids", [])),
                "Overview":     m.get("overview", ""),
            })
    return movies

